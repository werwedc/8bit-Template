{
  "name": "8bit-template",
  "version": "0.1.0",
  "description": "Hackathon starter template for retro 8-bit web games — PixiJS v8 + pixi-filters + TypeScript",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "biome check --write .",
    "test": "vitest run",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "gsap": "^3.15.0",
    "howler": "^2.2.4",
    "pixi-filters": "^6.0.3",
    "pixi.js": "^8.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.8.0",
    "@types/howler": "^2.2.11",
    "@vitest/ui": "^1.6.0",
    "jsdom": "^24.0.0",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^5.4.0",
    "vite": "^5.3.0",
    "vitest": "^1.6.0"
  }
}
